---
// Approximate benchmark results across scanner architecture iterations
---

<div class="architecture-benchmark">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 780 420">
    <!-- Title -->
    <text x="390" y="32" text-anchor="middle"
          font-family="'DM Sans', sans-serif"
          font-size="18" font-weight="600" fill="#1A1A1A">
      Benchmark Results by Architecture
    </text>
    <text x="390" y="52" text-anchor="middle"
          font-family="'DM Sans', sans-serif"
          font-size="12" fill="#9A9A9A" font-style="italic">
      Approximate figures from internal evaluation. Not peer-reviewed.
    </text>

    <!-- Y-axis -->
    <line x1="180" y1="80" x2="180" y2="330" stroke="#D0D0D0" stroke-width="1.5"/>
    <!-- Y-axis labels -->
    <text x="170" y="85" text-anchor="end" font-family="'DM Sans', sans-serif" font-size="11" fill="#9A9A9A">100%</text>
    <line x1="175" y1="80" x2="180" y2="80" stroke="#D0D0D0" stroke-width="1.5"/>
    <text x="170" y="147" text-anchor="end" font-family="'DM Sans', sans-serif" font-size="11" fill="#9A9A9A">75%</text>
    <line x1="175" y1="142.5" x2="730" y2="142.5" stroke="#E8E5DF" stroke-width="1" stroke-dasharray="4 4"/>
    <text x="170" y="210" text-anchor="end" font-family="'DM Sans', sans-serif" font-size="11" fill="#9A9A9A">50%</text>
    <line x1="175" y1="205" x2="730" y2="205" stroke="#E8E5DF" stroke-width="1" stroke-dasharray="4 4"/>
    <text x="170" y="272" text-anchor="end" font-family="'DM Sans', sans-serif" font-size="11" fill="#9A9A9A">25%</text>
    <line x1="175" y1="267.5" x2="730" y2="267.5" stroke="#E8E5DF" stroke-width="1" stroke-dasharray="4 4"/>
    <text x="170" y="335" text-anchor="end" font-family="'DM Sans', sans-serif" font-size="11" fill="#9A9A9A">0%</text>

    <!-- X-axis -->
    <line x1="180" y1="330" x2="730" y2="330" stroke="#D0D0D0" stroke-width="1.5"/>

    <!-- GROUP 1: Semgrep Output -->
    <!-- Detection rate: ~41% -->
    <rect x="220" y="227.5" width="50" height="102.5" rx="4" fill="#FAF8F5" stroke="#E8E5DF" stroke-width="2"/>
    <text x="245" y="222" text-anchor="middle" font-family="'DM Sans', sans-serif" font-size="11" fill="#6B6B6B">41%</text>
    <!-- False positive rate: ~76% -->
    <rect x="275" y="140" width="50" height="190" rx="4" fill="#F05D23" opacity="0.2" stroke="#F05D23" stroke-width="2"/>
    <text x="300" y="135" text-anchor="middle" font-family="'DM Sans', sans-serif" font-size="11" fill="#F05D23">76%</text>
    <!-- Label -->
    <text x="272" y="355" text-anchor="middle" font-family="'DM Sans', sans-serif" font-size="12" font-weight="600" fill="#6B6B6B">Semgrep</text>
    <text x="272" y="370" text-anchor="middle" font-family="'DM Sans', sans-serif" font-size="11" fill="#9A9A9A">Output</text>

    <!-- GROUP 2: Full Codebase -->
    <!-- Detection rate: ~68% -->
    <rect x="400" y="160" width="50" height="170" rx="4" fill="#FAF8F5" stroke="#E8E5DF" stroke-width="2"/>
    <text x="425" y="155" text-anchor="middle" font-family="'DM Sans', sans-serif" font-size="11" fill="#6B6B6B">68%</text>
    <!-- False positive rate: ~52% -->
    <rect x="455" y="200" width="50" height="130" rx="4" fill="#F05D23" opacity="0.2" stroke="#F05D23" stroke-width="2"/>
    <text x="480" y="195" text-anchor="middle" font-family="'DM Sans', sans-serif" font-size="11" fill="#F05D23">52%</text>
    <!-- Label -->
    <text x="452" y="355" text-anchor="middle" font-family="'DM Sans', sans-serif" font-size="12" font-weight="600" fill="#6B6B6B">Full</text>
    <text x="452" y="370" text-anchor="middle" font-family="'DM Sans', sans-serif" font-size="11" fill="#9A9A9A">Codebase</text>

    <!-- GROUP 3: Agentic Retrieval -->
    <!-- Detection rate: ~79% -->
    <rect x="580" y="132.5" width="50" height="197.5" rx="4" fill="#FAF8F5" stroke="#E8E5DF" stroke-width="2"/>
    <text x="605" y="127" text-anchor="middle" font-family="'DM Sans', sans-serif" font-size="11" fill="#6B6B6B">79%</text>
    <!-- False positive rate: ~38% -->
    <rect x="635" y="235" width="50" height="95" rx="4" fill="#F05D23" opacity="0.2" stroke="#F05D23" stroke-width="2"/>
    <text x="660" y="230" text-anchor="middle" font-family="'DM Sans', sans-serif" font-size="11" fill="#F05D23">38%</text>
    <!-- Label -->
    <text x="632" y="355" text-anchor="middle" font-family="'DM Sans', sans-serif" font-size="12" font-weight="600" fill="#6B6B6B">Agentic</text>
    <text x="632" y="370" text-anchor="middle" font-family="'DM Sans', sans-serif" font-size="11" fill="#9A9A9A">Retrieval</text>

    <!-- Legend -->
    <rect x="280" y="393" width="14" height="14" rx="3" fill="#FAF8F5" stroke="#E8E5DF" stroke-width="2"/>
    <text x="300" y="405" font-family="'DM Sans', sans-serif" font-size="12" fill="#6B6B6B">Detection Rate</text>
    <rect x="420" y="393" width="14" height="14" rx="3" fill="#F05D23" opacity="0.2" stroke="#F05D23" stroke-width="2"/>
    <text x="440" y="405" font-family="'DM Sans', sans-serif" font-size="12" fill="#F05D23">False Positive Rate</text>
  </svg>
</div>
